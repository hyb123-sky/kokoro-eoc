# ============================================
# KOKORO EOC - Environment Variables
# ============================================
# 复制此文件为 .env.local 并填入实际值

# ============================================
# ServiceNow 配置
# ============================================
# 你的 PDI 实例 URL (不要包含末尾斜杠)
VITE_SERVICENOW_INSTANCE_URL=https://dev123456.service-now.com

# ServiceNow 用户名 (推荐使用专用集成用户)
VITE_SERVICENOW_USERNAME=admin

# ServiceNow 密码
VITE_SERVICENOW_PASSWORD=your_password_here

# ============================================
# Mapbox 配置 (可选，用于真实地图)
# ============================================
# 访问 https://account.mapbox.com 获取 token
VITE_MAPBOX_ACCESS_TOKEN=pk.xxx

# ============================================
# 天气 API (Open-Meteo 免费，无需 key)
# ============================================
# 如果使用 OpenWeatherMap
# VITE_OPENWEATHER_API_KEY=your_api_key

# ============================================
# AI Copilot 配置 (可选)
# ============================================
# OpenAI API Key
VITE_OPENAI_API_KEY=sk-xxx

# Anthropic API Key (Claude)
VITE_ANTHROPIC_API_KEY=sk-ant-xxx

# ============================================
# Firebase/Supabase 配置 (用于实时数据)
# ============================================
# Firebase
# VITE_FIREBASE_API_KEY=xxx
# VITE_FIREBASE_AUTH_DOMAIN=xxx.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=xxx
# VITE_FIREBASE_DATABASE_URL=https://xxx.firebaseio.com

# Supabase (替代方案)
# VITE_SUPABASE_URL=https://xxx.supabase.co
# VITE_SUPABASE_ANON_KEY=xxx
